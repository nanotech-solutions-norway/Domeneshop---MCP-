# Domeneshop MCP environment template
# Do not rename this file to a live environment file inside the repository.
# Store real values only in server-side runtime settings or GitHub Actions protected variables.

NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info

# Core safety lock
WRITE_TOOLS_ENABLED=false
DRY_RUN_DEFAULT=true
REQUIRE_OPERATOR_APPROVAL=true

# Domeneshop API
DOMENESHOP_API_BASE_URL=https://api.domeneshop.no/v0
DS_AUTH_USER=__SET_IN_SECRET_STORE__
DS_AUTH_VALUE=__SET_IN_SECRET_STORE__

# SFTP/SCP read connector placeholders for Phase 3
DOMENESHOP_SFTP_HOST=sftp.domeneshop.no
DOMENESHOP_SFTP_PORT=22
DS_SFTP_USER=__SET_IN_SECRET_STORE__
DS_SFTP_VALUE=__SET_IN_SECRET_STORE__
DOMENESHOP_REMOTE_ROOT=/www

# Path jail
ALLOWED_REMOTE_ROOTS=/www,/www/solarex_forms,/www/atlas_control,/www/atlas_pip2
MAX_READ_FILE_BYTES=262144
ALLOWED_TEXT_EXTENSIONS=.txt,.md,.json,.csv,.html,.htm,.css,.js,.php,.xml,.yml,.yaml,.log

# Audit and backup
AUDIT_LOG_DIR=./audit
BACKUP_DIR=./backups
BACKUP_BEFORE_OVERWRITE=true

# Health targets, comma-separated
HEALTH_TARGETS=https://forms.nanotech-solutions.com/solarex_forms/health.php,https://pip.atlas-ai.no/health.php
